# Symphony / Maestro local environment template.
#
# Copy this file to a local, ignored file before filling secrets, for example:
#
#   cp .env.example .env.tapd.local
#   cp .env.example .env.linear.local
#
# Do not put real secrets in .env.example. Local files matching .env.* are
# ignored by git, except this tracked .env.example template.

# ── Common ────────────────────────────────────────────────────────────────
# Isolated workspace root used by real workflows.
# Example: $HOME/maestro-workspaces/tapd-cnb-codebuddy
SYMPHONY_WORKSPACE_ROOT=

# Optional: override agent credential store root.
SYMPHONY_AGENT_CREDENTIALS_STORE_ROOT=

# ── TAPD tracker ──────────────────────────────────────────────────────────
# Required for TAPD-backed workflows.
TAPD_API_USER=
TAPD_API_PASSWORD=
TAPD_WORKSPACE_ID=

# Optional: TAPD comment author. If empty, the authenticated API user is used.
TAPD_COMMENT_AUTHOR=

# Optional: narrow TAPD workflow probing/scanning to one Story/workitem type.
TAPD_WORKITEM_TYPE_ID=

# ── Linear tracker ────────────────────────────────────────────────────────
# Required for Linear-backed workflows.
LINEAR_API_KEY=
LINEAR_PROJECT_SLUG=

# ── Source repository ─────────────────────────────────────────────────────
# Used by CNB/GitHub repo-provider workflows.
SOURCE_REPO_URL=
SOURCE_REPO_BASE_BRANCH=main
SOURCE_REPO_BRANCH_WORK_PREFIX=maestro/

# Optional override. Usually inferred from SOURCE_REPO_URL for standard
# GitHub/CNB clone URLs.
SOURCE_REPO_PROVIDER_REPOSITORY=

# Optional GitHub PR label requirement. Leave empty if not needed.
SOURCE_REPO_PROVIDER_REQUIRED_PR_LABEL=

# ── CNB repo provider ─────────────────────────────────────────────────────
CNB_TOKEN=
CNB_GIT_USER_NAME=Maestro CNB
CNB_GIT_USER_EMAIL=maestro-cnb@example.invalid

# ── GitHub repo provider ──────────────────────────────────────────────────
# Either authenticate with `gh auth login`, or set one of these tokens locally.
GH_TOKEN=
GITHUB_TOKEN=

# ── CodeBuddy Code managed credential login ───────────────────────────────
# Used only when running `symphony accounts login codebuddy_code ...`.
CODEBUDDY_API_KEY=

# ── OpenCode managed credential login ─────────────────────────────────────
# Fill the provider key you use, then run the matching accounts login command.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
