# Basic runtime settings.
# Choose the matching compose.integration.yml profile. Each profile maps its
# provider-specific template variable to SYMPHONY_TEMPLATE inside the container.
SYMPHONY_PORT=4000
SYMPHONY_OPENCODE_TEMPLATE=linear/github/opencode
SYMPHONY_CODEX_TEMPLATE=linear/github/codex
SYMPHONY_CLAUDE_CODE_TEMPLATE=linear/github/claude_code
SYMPHONY_CODEBUDDY_TEMPLATE=tapd/cnb/codebuddy_code
SYMPHONY_WORKFLOW_PATH=
SYMPHONY_WORKSPACE_ROOT=/workspaces
SYMPHONY_AGENT_CREDENTIALS_STORE_ROOT=/app/.symphony/agent_credentials
SYMPHONY_AGENT_CREDENTIAL_PREFLIGHT=auto
# auth runs a minimal provider probe and may make a small API/model call. Use command for command-only checks.
SYMPHONY_AGENT_CREDENTIAL_PREFLIGHT_VERIFY_MODE=auth
SYMPHONY_AGENT_CREDENTIAL_PREFLIGHT_VERIFY_PROMPT=Reply with exactly OK.
SYMPHONY_AGENT_CREDENTIAL_ACCOUNT_ID=

# Linear workflows
LINEAR_API_KEY=
LINEAR_PROJECT_SLUG=

# TAPD workflows
TAPD_API_USER=
TAPD_API_PASSWORD=
TAPD_WORKSPACE_ID=
TAPD_COMMENT_AUTHOR=
TAPD_WORKITEM_TYPE_ID=

# Repository-backed workflows
SOURCE_REPO_URL=
SOURCE_REPO_BASE_BRANCH=main
SOURCE_REPO_BRANCH_WORK_PREFIX=maestro/
SOURCE_REPO_PROVIDER_REPOSITORY=
SOURCE_REPO_PROVIDER_REQUIRED_PR_LABEL=

# Repository provider credentials. Set only the provider used by the selected template.
GH_TOKEN=
GITHUB_TOKEN=
CNB_TOKEN=
CNB_GIT_USER_NAME=Maestro CNB
CNB_GIT_USER_EMAIL=maestro-cnb@example.invalid

# Agent provider credentials. Prefer Docker secrets or read-only file mounts in shared environments.
ZAI_API_KEY=
SYMPHONY_OPENCODE_CREDENTIAL_ENV_NAME=
SYMPHONY_OPENCODE_TOKEN_ENV=
CODEBUDDY_API_KEY=
SYMPHONY_CODEBUDDY_TOKEN_ENV=CODEBUDDY_API_KEY
CODEBUDDY_INTERNET_ENVIRONMENT=
CODEBUDDY_BASE_URL=
SYMPHONY_CODEX_TOKEN_ENV=OPENAI_API_KEY
OPENAI_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
SYMPHONY_CLAUDE_CODE_TOKEN_ENV=CLAUDE_CODE_OAUTH_TOKEN
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Agent runtime image build pins used by deploy/compose/compose.integration.yml profiles.
OPENCODE_VERSION=1.14.33
CODEX_VERSION=0.135.0
CLAUDE_CODE_VERSION=2.1.158
CODEBUDDY_VERSION=2.99.1

# CodeBuddy runtime config directory. The CodeBuddy profile persists it with a named volume.
CODEBUDDY_CONFIG_DIR=/home/symphony/.codebuddy
# Codex and Claude Code runtime config directories. Their profiles persist them with named volumes.
CODEX_HOME=/home/symphony/.codex
CLAUDE_CONFIG_DIR=/home/symphony/.claude

# Optional local file mounts used by deploy/compose/compose.integration.yml profiles.
# Set this only when using SYMPHONY_WORKFLOW_PATH with a workflow generated for the selected provider.
# OpenCode example: ./elixir/quickstart/WORKFLOW.linear-github-opencode.local.md
# CodeBuddy example: ./elixir/quickstart/WORKFLOW.tapd-cnb-codebuddy.local.md
# For Codex or Claude Code, use this only if you maintain a custom local workflow file.
SYMPHONY_WORKFLOW_FILE=
OPENCODE_CONFIG=./secrets/opencode.json
SSH_PRIVATE_KEY=./secrets/id_rsa
